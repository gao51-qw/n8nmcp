# Copy to .env.app on the VPS — runtime secrets for the main app container.
# DO NOT commit. Fill from your existing Lovable Cloud secrets.

NODE_ENV=production

# ─── Supabase (Lovable Cloud) ──────────────────────────────────────────────
SUPABASE_URL=https://vgmnndaoxbjsnvqhvuhf.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...      # server-only, never expose

# Same values exposed to the client at build time (already baked into the image
# during `docker build` if you used --build-arg; otherwise the publishable key
# falls back to runtime process.env at SSR boundary)
VITE_SUPABASE_URL=https://vgmnndaoxbjsnvqhvuhf.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
VITE_SUPABASE_PROJECT_ID=vgmnndaoxbjsnvqhvuhf

# ─── Encryption (REQUIRED in production) ───────────────────────────────────
# 32-byte master key for AES-256-GCM (encrypts user n8n API keys at rest).
# Generate ONCE with:  openssl rand -base64 32
# DO NOT change after first run — would invalidate every stored ciphertext.
# DO NOT lose — back up to your password manager. Without it the app can no
# longer decrypt n8n credentials and users must re-enter them all.
APP_ENCRYPTION_KEY=

# ─── Public URL (used by Stripe success/cancel & webhooks) ─────────────────
APP_PUBLIC_URL=https://app.n8nworkflow.com

# ─── Lovable AI Gateway ────────────────────────────────────────────────────
LOVABLE_API_KEY=

# ─── Stripe billing (required if you enable paid tiers) ────────────────────
# Get keys from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
# Webhook signing secret from https://dashboard.stripe.com/webhooks
# Endpoint URL to add there:  https://app.n8nworkflow.com/api/public/stripe-webhook
# Subscribe to events: checkout.session.completed, customer.subscription.updated,
#                      customer.subscription.deleted, invoice.payment_failed
STRIPE_WEBHOOK_SECRET=whsec_...
# Recurring price IDs (create products in Stripe dashboard first)
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_ENTERPRISE=price_...

# ─── Upstream MCP knowledge container ──────────────────────────────────────
# (Called only by the app server over the docker network; end users hit the
# app's per-user gateway at /api/public/mcp instead.)
MCP_UPSTREAM_URL=http://mcp:3000/mcp
MCP_UPSTREAM_TOKEN=same-as-MCP_AUTH_TOKEN-in-.env

# ─── Logging ───────────────────────────────────────────────────────────────
# json (default in prod) | pretty (dev only)
LOG_FORMAT=json
LOG_LEVEL=info
