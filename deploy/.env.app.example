# Copy to .env.app on the VPS — runtime secrets for the main app container.
# DO NOT commit. Fill these from your production secret manager.

NODE_ENV=production

# ─── Public split-domain URLs ──────────────────────────────────────────────
NEXT_PUBLIC_MCP_SITE_URL=https://mcp.n8nworkflow.com
NEXT_PUBLIC_MCP_ENDPOINT_URL=https://mcp.n8nworkflow.com/mcp
NEXT_PUBLIC_DOCS_URL=https://docs.n8nworkflow.com
NEXT_PUBLIC_BLOG_URL=https://blog.n8nworkflow.com
NEXT_PUBLIC_DASHBOARD_URL=https://dashboard.n8nworkflow.com
NEXT_PUBLIC_SECURITY_EMAIL=server@n8nworkflow.com

# Optional social URLs used in SEO metadata.
NEXT_PUBLIC_GITHUB_URL=
NEXT_PUBLIC_LINKEDIN_URL=
NEXT_PUBLIC_X_URL=
NEXT_PUBLIC_YOUTUBE_URL=

# ─── Supabase ──────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...      # server-only, never expose

# ─── Encryption (REQUIRED in production) ───────────────────────────────────
# 32-byte master key for AES-256-GCM (encrypts user n8n API keys at rest).
# Generate ONCE with:  openssl rand -base64 32
# DO NOT change after first run — would invalidate every stored ciphertext.
# DO NOT lose — back up to your password manager. Without it the app can no
# longer decrypt n8n credentials and users must re-enter them all.
APP_ENCRYPTION_KEY=

# ─── Paddle billing (required if you enable paid tiers) ────────────────────
PADDLE_ENV=production
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_PRICE_PRO=
PADDLE_PRICE_ENTERPRISE=

# Bearer token used only by VPS cron for internal billing reconciliation.
BILLING_CRON_SECRET=

# ─── Upstream n8n knowledge MCP container ──────────────────────────────────
# Operator-owned server configuration. Compose pins the same values on every app
# deployment so requests cannot redirect this trust exception at runtime.
# End users connect to the app gateway, never directly to this container.
UPSTREAM_N8N_MCP_URL=http://mcp:3000/mcp
UPSTREAM_N8N_MCP_TOKEN=same-as-MCP_AUTH_TOKEN-in-.env
ENABLE_MULTI_TENANT=true

# ─── Rate limiting ─────────────────────────────────────────────────────────
# Recommended in multi-container production; leave blank only for local dev.
RATE_LIMITER=supabase
MCP_SHORT_WINDOW_LIMITER=supabase

# ─── Logging ───────────────────────────────────────────────────────────────
# json (default in prod) | pretty (dev only)
LOG_FORMAT=json
LOG_LEVEL=info

# ─── Support observability ─────────────────────────────────────────────────
# NEXT_PUBLIC_SENTRY_DSN is safe for the browser; all remaining values are
# server/build secrets and must not be exposed through NEXT_PUBLIC_*.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_TRACES_SAMPLE_RATE=0.05

# ─── Support email and automation ──────────────────────────────────────────
RESEND_API_KEY=
SUPPORT_EMAIL_FROM=server@n8nworkflow.com
SUPPORT_N8N_WEBHOOK_URL=
SUPPORT_N8N_WEBHOOK_SECRET=

# Bearer token used only by VPS cron for internal support maintenance routes.
SUPPORT_CRON_SECRET=
